DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cms_saris_dev?schema=public"

JWT_SECRET="cms-saris-dev-secret-change-in-production"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"

# Clé de chiffrement at-rest des secrets TOTP (AES-256-GCM). À CHANGER en production.
# Ne JAMAIS la modifier après que des 2FA ont été enrôlées, sinon les secrets
# existants deviennent indéchiffrables.
TOTP_ENC_KEY="cms-saris-dev-totp-encryption-key-change-in-production"

# Clé de chiffrement at-rest de la messagerie interne (messages + pièces jointes,
# AES-256-GCM). Clé DÉDIÉE et explicite (sinon repli sur TOTP_ENC_KEY). À CHANGER
# en production. Ne JAMAIS la modifier après l'envoi de messages, sinon les
# contenus existants deviennent indéchiffrables.
# (En dev : valeur identique au repli historique pour ne pas casser les messages déjà créés.)
MESSAGE_ENC_KEY="cms-saris-dev-totp-encryption-key-change-in-production"

PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
