DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/cms_saris_dev?schema=public"

JWT_SECRET="your-secret-key-here"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"

# Clé de chiffrement at-rest des secrets TOTP (AES-256-GCM). Phrase longue et unique.
# Ne JAMAIS la modifier après enrôlement de 2FA (rend les secrets indéchiffrables).
TOTP_ENC_KEY="change-me-totp-encryption-key"

# (Optionnel) Clé de chiffrement de la MESSAGERIE interne (AES-256-GCM, at-rest).
# Si absente : repli automatique sur TOTP_ENC_KEY (suffisant en dev). En production,
# utiliser une clé dédiée. Rotation multi-clés possible :
#   MESSAGE_ENC_KEYS="1:phraseA,2:phraseB"  +  MESSAGE_ENC_KEY_CURRENT="2"
# ou via un fichier de secrets monté :       MESSAGE_ENC_KEYS_FILE="/run/secrets/msg_keys"
MESSAGE_ENC_KEY="change-me-message-encryption-key"

PORT=3000
NODE_ENV=development

# Frontend autorisé (CORS)
FRONTEND_URL="http://localhost:5173"

# Confiance proxy — pour récupérer la VRAIE IP client derrière un reverse-proxy.
# Nombre de proxys en amont : "1" = un seul (nginx/traefik direct), "2" = ex. Cloudflare + nginx.
# "true" = faire confiance à tous (à éviter en prod), "false" = aucun (accès direct sans proxy).
# Par défaut (non défini) : 1.
TRUST_PROXY=1
