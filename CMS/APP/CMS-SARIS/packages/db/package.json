{
  "name": "@cms-saris/db",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate":  "prisma migrate dev",
    "db:studio":   "prisma studio",
    "db:reset":    "prisma migrate reset",
    "db:seed":     "tsx prisma/seed.ts",
    "db:sync-permissions": "tsx prisma/sync-permissions.ts",
    "db:sqlite:gen":      "node scripts/gen-sqlite-schema.mjs",
    "db:sqlite:migrate":  "prisma migrate dev --schema prisma/sqlite/schema.prisma --skip-seed",
    "db:sqlite:deploy":   "prisma migrate deploy --schema prisma/sqlite/schema.prisma",
    "db:sqlite:generate": "prisma generate --schema prisma/sqlite/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcrypt": "^6.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node":   "^24.0.0",
    "prisma":        "^6.0.0",
    "tsx":           "^4.19.0",
    "typescript":    "^5.9.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
